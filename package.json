		"./oxlint/*": {
			"default": "./oxlint-configs/*.json"
		}
	},
	"scripts": {
		"gen-index": "tsx scripts/gen-index.ts",
		"gen-oxlintrc": "tsx scripts/generate-oxlintrc.ts",
		"build": "yarn gen-index && yarn gen-oxlintrc && tsdown",
		"lint": "yarn build && oxfmt --check && oxlint --type-aware src",
		"format": "yarn build && oxfmt && oxlint --type-aware src --fix --fix-suggestions",
		"fmt": "yarn format",
		"prepack": "yarn build",
		"update": "yarn upgrade-interactive"
	},
