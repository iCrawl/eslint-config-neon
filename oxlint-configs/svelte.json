{
  "plugins": [
    "import"
  ],
  "rules": {
    "import/first": 0,
    "import/no-duplicates": 0,
    "import/no-mutable-exports": 0,
    "import/prefer-default-export": 0,
    "import-x/first": 0,
    "import-x/no-duplicates": 0,
    "import-x/no-mutable-exports": 0,
    "import-x/prefer-default-export": 0
  }
}
